# FreightGPT UAE - FREE Setup (no paid services required!)
# ========================================================
# Just copy this to .env and run:
#   cd backend && pip install -r requirements.txt && uvicorn main:app --reload

# Database - FREE: SQLite (no server needed!)
# Switch to PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./freightgpt.db
DATABASE_URL_SYNC=sqlite:///./freightgpt.db

# Security (change this in production)
SECRET_KEY=freightgpt-dev-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / LLM
# FREE: Install Ollama (https://ollama.ai) then: ollama pull mistral
LLM_ROUTER_MODEL=ollama/mistral
FALLBACK_LLM=ollama/phi
OLLAMA_BASE_URL=http://localhost:11434

# Leave these empty to use free Ollama instead
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email - FREE: Use Gmail SMTP (optional)
# Create app password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Storage - FREE: Local filesystem (no S3 needed!)
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# Maps - FREE: OpenStreetMap (no API key needed!)
GOOGLE_MAPS_API_KEY=
OSM_USER_AGENT=FreightGPT-UAE/1.0

# App
APP_NAME=FreightGPT UAE
ENV=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]
